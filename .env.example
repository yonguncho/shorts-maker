# shorts_maker 환경변수 템플릿
# 실제 값은 .env 에 채운다(이 파일은 이름만 담은 템플릿, 값은 비움).
# .env 는 .gitignore 로 제외됨. 키 값은 ENVIRONMENT.md 에 기록하지 말 것(보유 여부만 추적).
#
# ── 사용법 ──
#   cp .env.example .env  하고 값 채우기
#
# 아래 키 이름은 모두 TODO 예시. 실제 사용 서비스 확정 시 추가/수정한다.

# === 노드 식별 (상태버스 공통) ===
NODE_ID=mac-shorts-01
MACHINE=mac
PIPELINE_ID=shorts_maker

# === 증시 데이터: Finnhub (확정) ===
FINNHUB_API_KEY=
FINNHUB_WEBHOOK_SECRET=

# === SEC EDGAR (공시, 무료) — User-Agent에 연락처 권장 ===
SEC_USER_AGENT=shorts-maker/0.1 (contact: your-email@example.com)

# === LLM / 에이전트 (TODO) ===
# ANTHROPIC_API_KEY=        # claude CLI는 자체 로그인 사용 가능 — 필요 시에만
# OPENAI_API_KEY=           # Codex/adversarial 용 (도입 확정 후)

# === 미디어 / 자산 (TODO) ===
# BGM_LIBRARY_PATH=         # 배경음악 라이브러리 경로
# FONT_PATH=                # 자막 폰트 경로

# === 원격/알림 (선택) ===
# TAILSCALE_AUTHKEY=        # 무인 Tailscale 등록 시
